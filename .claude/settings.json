{
    "env": {
        "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "4096",
        "MAX_MCP_OUTPUT_TOKENS": "25000"
    },
    "permissions": {
        "defaultMode": "plan",
        "allow": [
            "Edit(app/assets/**/*)",
            "Edit(app/config/**/*)",
            "Edit(app/src/**/*)",
            "Edit(app/templates/**/*)",
            "Edit(app/tests/**/*)",
            "Edit(app/translations/**/*)",
            "Bash(git:*)"
        ],
        "deny": [
            "Bash(rm:*)"
        ]
    }
}
